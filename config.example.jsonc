// Example config for paperclip-plugin-chat-bots.
// Set via: POST /api/plugins/:id/config  with body { "configJson": { ...this... } }
// (JSONC here for comments — send real JSON to the API.)
{
  "telegram": {
    "enabled": true,
    // Each bot has a `mode`:
    //   "concierge" (default) — one front-door identity that routes across a roster of agents and
    //                           replies in one voice; specialists are never surfaced to the user.
    //   "direct"              — bound to its single `agent`, no cross-delegation.
    // The agents a user can actually reach through a bot = (the bot's offering) ∩ (the user's
    // rules.users scope). Topic routing within that set is the cheap model's job (llm.agents blurbs).
    // Provide the token via ONE of: botTokenFile (recommended) | botTokenEnv | botTokenRef.
    "bots": [
      // Single concierge front door (e.g. Chad): routes to anyone in `roster` (or all llm.agents if omitted).
      {
        "agent": "chad",
        "botTokenFile": "/paperclip/.paperclip/chat-bots/tg-token-chad",
        "mode": "concierge",
        "roster": ["brendina", "gregory", "emma", "researcher"]
        // "allowUsers": ["*"]   // optional per-bot DM allow-list; omit to rely on rules.users
      }
      // Or direct specialist bots (no cross-delegation):
      // { "agent": "emma", "botTokenFile": "/paperclip/.paperclip/chat-bots/tg-token-emma", "mode": "direct" }
    ],
    "pollIntervalMs": 1500,
    "drainOnStart": true
  },

  // WhatsApp is a Phase 2 stub today.
  "whatsapp": { "enabled": false },

  // Optional: alias -> Paperclip agentId. If omitted, aliases resolve by agent urlKey/name.
  "agentAliases": {
    "support": "<agentId>",
    "eng": "<agentId>"
  },

  // Access control: default-deny, per Telegram user id -> allowed agent aliases.
  "rules": {
    "defaultDeny": true,
    "defaultAgent": "support",
    "users": {
      "<telegramUserId_owner>":    { "name": "Owner",    "agents": ["*"] },
      "<telegramUserId_teammate>": { "name": "Teammate", "agents": ["support"] }
    }
  },

  // Optional outbound notifications (sent via the chosen bot).
  "notify": {
    "defaultChatId": "<telegramChatId>",
    "agent": "support",
    "onApproval": true,
    "onIssueCreated": false
  },

  // Cheap router/concierge tier (OpenAI-compatible). The model does NOT do work itself: it decides,
  // per message, whether to CONTINUE the chat's active thread (post the message as a comment so the
  // assigned agent resumes), open a NEW thread (delegate to the best-fit agent as a tracked issue),
  // or REPLY directly (greetings / one clarifying question). Agent results are summarised back in one
  // voice. Provide the key via ONE of: apiKeyFile (recommended) | apiKeyEnv | apiKeyRef.
  "llm": {
    "enabled": true,
    "baseUrl": "https://api.fireworks.ai/inference/v1",
    "model": "accounts/fireworks/models/kimi-k2p6",
    "apiKeyFile": "/paperclip/.paperclip/chat-bots/fireworks-key",
    "maxTokens": 1024,
    "temperature": 0.4,
    "historyTurns": 12,
    "summarizeReplies": true,
    // Delegation roster: agent alias -> short role blurb. Drives the model's topic routing; always
    // filtered to (bot roster ∩ user scope) at runtime.
    "agents": {
      "brendina": "CTO — engineering, infrastructure, DevOps, code, technical investigation.",
      "gregory": "Executive assistant — scheduling, email, ops, partnerships, general requests.",
      "emma": "CMO — marketing, content, social media, community, PR, brand.",
      "researcher": "Research — web research, fact-finding, competitive/market lookups."
    }
  },

  // Messages starting with one of these commands open a tracked issue routed to the resolved
  // agent (full agent w/ tools/skills) instead of a cheap chat reply. Also: "/reset" clears the
  // chat history for the current conversation.
  "escalate": { "commands": ["/task", "/issue"] },

  // Board API — needed to relay agents' follow-up questions back to chat (interaction answers).
  // apiBase must be the canonical host URL (the loopback enforces a hostname allowlist).
  "board": {
    "keyFile": "/paperclip/.paperclip/chat-bots/board-key",
    "apiBase": "https://paperclip.example.com"
  },

  // Optional: builds "open full reply in Paperclip" links on truncated messages.
  "paperclipPublicUrl": "https://paperclip.example.com",
  "maxReplyChars": 900
}
